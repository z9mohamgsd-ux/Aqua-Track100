modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev & PORT=19907 BASE_PATH=/ pnpm --filter @workspace/aquatrack run dev"
waitForPort = 19907

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
JWT_SECRET = "aquatrack-jwt-secret-key-2024-xK9mP3qR7nL1vB5w"
JWT_EXPIRES_IN = "7d"
FRONTEND_URL = "https://63c31363-6404-4a0c-8ea7-fc1cc0c7c4c2-00-16xgwr89ddtr6.janeway.replit.dev"
VITE_GOOGLE_ENABLED = "true"
